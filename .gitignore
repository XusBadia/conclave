# Rust build artifacts
/target/
**/*.rs.bk
Cargo.lock.bak

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Claude Code worktrees / scratch state
/.claude/

# Conclave runtime data (user-local workspaces, secrets)
*.env
.env
.env.*
!.env.example
conclave.toml.local
/data/
/tmp/

# Real-patient evaluation corpus for `conclave-cli eval` — NEVER commit PHI.
# The synthetic manifest (eval/synthetic.json) is committed; real cases live
# here and stay local.
/eval/corpus/

# FastEmbed downloaded ONNX models (~470 MB). Cached at OS-standard cache
# dir at runtime; this catches the legacy CWD-relative location.
.fastembed_cache/

# Mobile icon byproducts of `pnpm tauri icon` — Conclave is desktop-only.
apps/desktop/src-tauri/icons/android/
apps/desktop/src-tauri/icons/ios/
